# ---- Gmail (OAuth2) ----
# Create an OAuth Client (type: Web application) in Google Cloud Console,
# enable the Gmail API, and add http://localhost:3000/oauth2callback as a redirect URI.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/oauth2callback
# Filled in by `npm run authorize`
GMAIL_REFRESH_TOKEN=

# ---- Groq — analysis engine (key starts with gsk_) ----
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Serper.dev (web context) ----
# API key from https://serper.dev (dashboard → API Key)
SERPER_API_KEY=

# ---- Notion (dump results to the 📥 Inbox page) ----
# Internal integration token; the 📥 Inbox page must be shared with this integration.
NOTION_TOKEN=
# 📥 Inbox page under 🏠 Life HQ — daily results are appended here, one line per item.
NOTION_INBOX_PAGE_ID=

